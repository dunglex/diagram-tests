    PRODUCT_VARIANT ||--o{ INVENTORY : tracked_in
    PRODUCT_VARIANT ||--o{ CART_ITEM : "in_cart"
    PRODUCT_VARIANT ||--o{ ORDER_ITEM : "in_order"
    
    WAREHOUSE ||--o{ INVENTORY : contains
    
    CART ||--o{ CART_ITEM : contains
    
    COUPON ||--o{ ORDER : applied_to
    
    ORDER ||--|{ ORDER_ITEM : contains
    ORDER ||--|{ PAYMENT : receives
    ORDER ||--|{ SHIPMENT : generates
    
    SHIPPING_METHOD ||--o{ SHIPMENT : used_by
    
